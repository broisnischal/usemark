{
  "name": "tanstarter",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run format && bun run lint",
    "prepare": "husky",
    "db": "drizzle-kit",
    "deps": "bunx taze@latest -Ilw",
    "deps:major": "bunx taze@latest major -Ilw",
    "tanstack": "bunx @tanstack/cli@latest",
    "ui": "bunx shadcn@latest",
    "auth": "bunx auth@latest",
    "auth:secret": "bunx auth@latest secret",
    "auth:generate": "bunx auth@latest generate --config ./src/lib/auth/auth.ts --y --output ./src/lib/db/schema/auth.schema.ts",
    "auth:migrate": "bun run auth:generate && bun run db generate && bun run db migrate",
    "migrate": "bun run db generate && bun run db migrate",
    "db:generate:prod": "bun --env-file=.env run db generate",
    "db:push:prod": "bun --env-file=.env run db push",
    "release:prod": "bun run db:generate:prod && bun run db:push:prod && bun run deploy",
    "skills": "bunx skills@latest",
    "intent": "bunx @tanstack/intent@latest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@better-auth/drizzle-adapter": "^1.6.5",
